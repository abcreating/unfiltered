generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── AUTH ────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String             @id @default(cuid())
  name                 String?
  email                String?            @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  role                 UserRole           @default(USER)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus @default(FREE)
  subscriptionEnd      DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  accounts    Account[]
  sessions    Session[]
  alerts      Alert[]
  bookmarks   Bookmark[]
  speechViews SpeechView[]
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

// ─── LEADERS ─────────────────────────────────────────────────

model Leader {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  nameLocal    String?
  country      String
  countryCode  String    @db.Char(2)
  organization String?
  role         String
  roleStart    DateTime?
  roleEnd      DateTime?
  photoUrl     String?
  bio          String?   @db.Text
  languages    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  speeches Speech[]

  @@index([country])
  @@index([slug])
}

// ─── SPEECHES ────────────────────────────────────────────────

model Speech {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  titleOriginal String?
  leaderId      String
  originalLang  String       @db.VarChar(10)
  deliveredAt   DateTime
  venue         String?
  city          String?
  country       String?
  countryCode   String?      @db.Char(2)
  occasion      String?
  duration      Int?
  videoUrl      String?
  videoSource   String?
  videoEmbedId  String?
  sourceUrl     String
  sourceLabel   String?
  status        SpeechStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  leader       Leader        @relation(fields: [leaderId], references: [id])
  paragraphs   Paragraph[]
  translations Translation[]
  tags         SpeechTag[]
  bookmarks    Bookmark[]
  mediaReports MediaReport[]
  aiContext    AiContext?
  speechViews  SpeechView[]

  @@index([leaderId])
  @@index([deliveredAt])
  @@index([originalLang])
  @@index([status])
  @@index([slug])
}

enum SpeechStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

// ─── PARAGRAPHS ──────────────────────────────────────────────

model Paragraph {
  id           String  @id @default(cuid())
  speechId     String
  index        Int
  text         String  @db.Text
  startTime    Float?
  endTime      Float?
  speakerLabel String?

  speech       Speech                @relation(fields: [speechId], references: [id], onDelete: Cascade)
  translations ParagraphTranslation[]

  @@unique([speechId, index])
  @@index([speechId])
}

// ─── TRANSLATIONS ────────────────────────────────────────────

model Translation {
  id         String             @id @default(cuid())
  speechId   String
  lang       String             @db.VarChar(10)
  title      String
  provider   TranslationProvider
  verified   Boolean            @default(false)
  verifiedBy String?
  verifiedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  speech     Speech                 @relation(fields: [speechId], references: [id], onDelete: Cascade)
  paragraphs ParagraphTranslation[]

  @@unique([speechId, lang])
  @@index([speechId])
  @@index([lang])
}

model ParagraphTranslation {
  id            String @id @default(cuid())
  translationId String
  paragraphId   String
  text          String @db.Text

  translation Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
  paragraph   Paragraph   @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@unique([translationId, paragraphId])
  @@index([translationId])
  @@index([paragraphId])
}

enum TranslationProvider {
  DEEPL
  GOOGLE
  HUMAN
  OFFICIAL
}

// ─── TAGS ────────────────────────────────────────────────────

model Tag {
  id       String      @id @default(cuid())
  slug     String      @unique
  name     String      @unique
  category TagCategory

  speeches SpeechTag[]
}

model SpeechTag {
  speechId String
  tagId    String

  speech Speech @relation(fields: [speechId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([speechId, tagId])
  @@index([tagId])
}

enum TagCategory {
  TOPIC
  EVENT
  REGION
  FORMAT
}

// ─── MEDIA REPORTS ───────────────────────────────────────────

model MediaReport {
  id          String    @id @default(cuid())
  speechId    String
  outlet      String
  headline    String
  url         String
  summary     String?   @db.Text
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  speech Speech @relation(fields: [speechId], references: [id], onDelete: Cascade)

  @@index([speechId])
}

// ─── AI CONTEXT ──────────────────────────────────────────────

model AiContext {
  id          String   @id @default(cuid())
  speechId    String   @unique
  background  String?  @db.Text
  keyTerms    Json?
  aftermath   String?  @db.Text
  modelUsed   String?
  generatedAt DateTime @default(now())

  speech Speech @relation(fields: [speechId], references: [id], onDelete: Cascade)
}

// ─── ALERTS ──────────────────────────────────────────────────

model Alert {
  id        String       @id @default(cuid())
  userId    String
  type      AlertType
  targetId  String
  channel   AlertChannel @default(EMAIL)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetId])
  @@index([userId])
  @@index([targetId])
}

enum AlertType {
  LEADER
  TOPIC
}

enum AlertChannel {
  EMAIL
  PUSH
  BOTH
}

// ─── BOOKMARKS ───────────────────────────────────────────────

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  speechId  String
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  speech Speech @relation(fields: [speechId], references: [id], onDelete: Cascade)

  @@unique([userId, speechId])
  @@index([userId])
  @@index([speechId])
}

// ─── SPEECH VIEWS (paywall tracking) ────────────────────────

model SpeechView {
  id       String   @id @default(cuid())
  userId   String
  speechId String
  viewedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  speech Speech @relation(fields: [speechId], references: [id], onDelete: Cascade)

  @@unique([userId, speechId])
  @@index([userId])
}

// ─── INGESTION LOG ───────────────────────────────────────────

model IngestionLog {
  id          String          @id @default(cuid())
  speechId    String?
  source      String
  method      IngestionMethod
  status      IngestionStatus
  error       String?         @db.Text
  metadata    Json?
  startedAt   DateTime        @default(now())
  completedAt DateTime?

  @@index([speechId])
  @@index([status])
}

enum IngestionMethod {
  MANUAL
  SCRAPER
  API
  UPLOAD
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
